<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/swapPool"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="—"
            android:textSize="13sp"
            android:paddingBottom="6dp" />

        <TextView
            android:id="@+id/swapBalance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="12sp"
            android:paddingBottom="12dp"
            android:visibility="gone" />

        <!-- Live external market price vs pool spot (USDT pairs only) — display-only arbitrage hint -->
        <TextView
            android:id="@+id/swapMarket"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="12sp"
            android:paddingBottom="12dp"
            android:visibility="gone" />

        <!-- FROM row -->
        <LinearLayout
            android:id="@+id/swapFromCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/swapFromLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="YOU PAY"
                    android:textSize="11sp"
                    android:letterSpacing="0.08" />

                <EditText
                    android:id="@+id/swapAmount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="0.0"
                    android:inputType="numberDecimal"
                    android:textSize="24sp"
                    android:background="@null"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/swapFromTok"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MINIMA"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- flip -->
        <TextView
            android:id="@+id/swapFlip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="⇅"
            android:textSize="22sp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:paddingLeft="18dp"
            android:paddingRight="18dp" />

        <!-- TO row -->
        <LinearLayout
            android:id="@+id/swapToCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="YOU RECEIVE (EST.)"
                    android:textSize="11sp"
                    android:letterSpacing="0.08" />

                <TextView
                    android:id="@+id/swapOut"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0.0"
                    android:textSize="24sp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/swapToTok"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="token"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- quote details -->
        <LinearLayout
            android:id="@+id/swapQuote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="12dp"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/swapBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SWAP"
            android:gravity="center"
            android:textSize="15sp"
            android:letterSpacing="0.08"
            android:padding="16dp"
            android:layout_marginTop="14dp" />

        <TextView
            android:id="@+id/swapStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:paddingTop="12dp" />

        <!-- inline recent-activity strip (borrowed from MinimaSwap: activity right under the swap) -->
        <LinearLayout
            android:id="@+id/swapActivity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="18dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
